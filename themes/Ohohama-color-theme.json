	],
	"tokenColors": [
		{
			"scope": "emphasis",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": "strong",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"scope": [
				"meta.diff.header",
				"comment",
			],
			"settings": {
				"foreground": "#ffffff"
			}
		},
		{
			"scope": [
				"entity.name.tag",
				"markup.heading",
				"punctuation.definition.tag",
				"keyword",
				"keyword.control",
				"meta.return-type",
				"support.class",
				"support.type",
				"entity.name.type",
				"entity.name.class",
				"source.cs storage.type",
			],
			"settings": {
				"foreground": "#33a7e4"
			}
		},
		{
			"scope": "markup.underline",
			"settings": {
				"fontStyle": "underline"
			}
		},
		{
			"scope": "markup.bold",
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.italic",
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"name": "JavaScript string interpolation ${}",
			"scope": [
				"punctuation.definition.template-expression.begin.js",
				"punctuation.definition.template-expression.begin.ts",
				"punctuation.definition.template-expression.end.ts",
				"punctuation.definition.template-expression.end.js"
			],
			"settings": {
				"foreground": "#33a7e4"
			}
		},
		{
			"name": "storage",
			"scope": [
				"storage.type.function.js",
				"storage.type.js"
			],
			"settings": {
				"foreground": "#0466c8",
			}
		},
		{
			"name": "variable",
			"scope": [
				"variable",
			],
			"settings": {
				"foreground": "#00b4d8",
			}
		},
		{
			"name": "entity",
			"scope": [
				"entity"
			],
			"settings": {
				"foreground": "#023e7d",
			}
		},
		{
			"name": "string",
			"scope": [
				"string"
			],
			"settings": {
				"foreground": "#979dac"
			}
		},
		{
			"name": "meta",
			"scope": [
				"meta"
			],
			"settings": {
				"foreground": "#ade8f4",
			}
		},
		{
			"name": "source",
			"scope": [
				"source"
			],
			"settings": {
				"foreground": "#88ccf1",
			}
		},
		{
			"name": "comment",
			"scope": [
				"comment"
			],
			"settings": {
				"foreground": "#a5a7a8",
			}
		}
	],

}
